# ════════════════════════════════════════════════════════
# BACKEND ENV — Imports China Brasil API
# ════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Most settings (API keys, SMTP, integrations) are configured
# through the admin panel UI and persisted in the database.
# This file only contains infrastructure/security values that
# MUST live in env vars.

# ── Database (REQUIRED) ──────────────────────────────────
# Postgres (production / Coolify)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# Or SQLite (local dev only — NOT recommended for production)
# DATABASE_URL=file:./prisma/dev.db

# ── Server ───────────────────────────────────────────────
PORT=9000
NODE_ENV=production

# ── Security (REQUIRED) ──────────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_64_CHAR_RANDOM_STRING

# Admin panel password — used to authenticate with /admin/auth
# Cannot be changed via UI (security)
ADMIN_SECRET=change-me-strong-password
# Alternative env name (legacy compatibility)
THEME_ADMIN_PASSWORD=change-me-strong-password

# ── CORS (REQUIRED in production) ────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourstore.com,https://admin.yourstore.com

# Public-facing storefront URL (used in OG, sitemaps, emails)
STORE_URL=https://yourstore.com

# ── Auto-migrate ─────────────────────────────────────────
# Set to "false" to disable automatic Prisma db push on startup
# Recommended: leave unset (auto-migrate is on by default)
# AUTO_MIGRATE=false

# ────────────────────────────────────────────────────────────
# THE FOLLOWING SETTINGS ARE NOW CONFIGURED VIA ADMIN UI
# (admin/theme → Configurações or Integrações)
# Listed here for reference / bootstrap before first login.
# ────────────────────────────────────────────────────────────

# Sentinel Tracking (configurable in admin)
# SENTINEL_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENTINEL_WEBHOOK_SECRET=auto-generated-via-admin-rotate

# SMTP — for order confirmation / abandoned cart emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-specific-password

# Stripe (alternative to Luna)
# STRIPE_SECRET_KEY=sk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Luna Checkout
# LUNA_WEBHOOK_SECRET=auto-generated

# Abandoned cart recovery
# ABANDONED_CART_COUPON=VOLTEI10
