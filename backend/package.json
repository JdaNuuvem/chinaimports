{
  "name": "underarmour-backend",
  "version": "1.0.0",
  "description": "Under Armour Store - Medusa.js Backend",
  "scripts": {
    "postinstall": "node scripts/prepare-schema.js && prisma generate",
    "dev": "node server.js",
    "start": "node server.js",
    "db:migrate": "node scripts/prepare-schema.js && npx prisma migrate dev",
    "db:push": "node scripts/prepare-schema.js && npx prisma db push",
    "db:seed": "node seed.js",
    "db:setup": "node scripts/prepare-schema.js && npx prisma db push && node seed.js",
    "prepare-schema": "node scripts/prepare-schema.js",
    "test": "node __tests__/api.test.js"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "stripe": "^21.0.0",
    "zod": "^4.3.6"
  }
}
