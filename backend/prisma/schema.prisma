generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Default sqlite for local dev. Production uses prisma/schema.postgres.prisma
  // (the Dockerfile swaps to postgres at build time when DATABASE_URL is postgresql).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String?
  handle      String   @unique
  thumbnail   String?
  videoUrl    String?
  weight      Int      @default(0)
  productType String   @default("physical") // physical | digital
  isFeatured  Boolean  @default(false)
  isGiftcard  Boolean  @default(false)
  tags        String?  // JSON array of tags
  metaTitle       String?
  metaDescription String?
  lunaCheckoutUrl String?  // Optional per-product Luna checkout URL — if set, replaces buy CTA action
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants    Variant[]
  options     ProductOption[]
  images      ProductImage[]
  reviews     Review[]
  collections CollectionProduct[]

  @@map("products")
}

model ProductOption {
  id        String              @id @default(cuid())
  title     String
  productId String
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductOptionValue[]

  @@map("product_options")
}

model ProductOptionValue {
  id       String        @id @default(cuid())
  value    String
  optionId String
  option   ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@map("product_option_values")
}

model Variant {
  id                String   @id @default(cuid())
  title             String
  sku               String?  @unique
  barcode           String?
  price             Int
  compareAtPrice    Int?
  inventoryQuantity Int      @default(0)
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("variants")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  altText   String?
  position  Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Collection {
  id        String              @id @default(cuid())
  title     String
  handle    String              @unique
  imageUrl  String?
  createdAt DateTime            @default(now())
  products  CollectionProduct[]

  @@map("collections")
}

model CollectionProduct {
  productId    String
  collectionId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@map("collection_products")
}

model Setting {
  key       String   @id
  value     String   // JSON-encoded value (string, number, boolean, object)
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Customer {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  tags         String?   // JSON array for segmentation
  wishlist     String?   // JSON array of product IDs
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses Address[]
  reviews   Review[]
  orders    Order[]
  sessions  Session[]

  @@map("customers")
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@map("sessions")
}

model Address {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  address1    String
  address2    String?
  city        String
  province    String
  postalCode  String
  countryCode String   @default("BR")
  phone       String?
  isDefault   Boolean  @default(false)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Cart {
  id              String     @id @default(cuid())
  shippingTotal   Int        @default(0)
  discountTotal   Int        @default(0)
  couponCode      String?
  shippingAddress String?
  billingAddress  String?
  shippingMethod  String?
  customerId      String?
  email           String?
  metadata        String?    // JSON for abandonment tracking, recovery_sent flags
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(cuid())
  quantity  Int
  cartId    String
  variantId String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   Variant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@map("cart_items")
}

model Order {
  id                String   @id @default(cuid())
  displayId         Int
  status            String   @default("pending")
  paymentStatus     String   @default("awaiting")
  fulfillmentStatus String   @default("not_fulfilled")
  total             Int
  subtotal          Int
  shippingTotal     Int      @default(0)
  discountTotal     Int      @default(0)
  couponCode        String?
  tags              String?  // JSON array of tags
  shippingAddress   String?
  stripePaymentId   String?
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  title     String
  quantity  Int
  unitPrice Int
  total     Int
  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id])
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Review {
  id            String   @id @default(cuid())
  rating        Int
  title         String
  body          String
  author        String
  customerEmail String?
  verified      Boolean  @default(false)
  images        String?
  source        String?
  sourceUrl     String?
  originalDate  String?
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  approved      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("reviews")
}

// ── Coupons/Discounts ──

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  type            String   @default("percentage") // percentage | fixed
  value           Int      // percentage (10 = 10%) or fixed amount in centavos
  minOrderAmount  Int?     // minimum cart value
  maxUses         Int?
  usedCount       Int      @default(0)
  active          Boolean  @default(true)
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  @@map("coupons")
}

// ── Shipping Options (configurable by store owner) ──

model ShippingOption {
  id        String  @id @default(cuid())
  name      String
  price     Int     // centavos
  minDays   Int     @default(3)
  maxDays   Int     @default(10)
  active    Boolean @default(true)

  @@map("shipping_options")
}

// ── URL Redirects ──

model Redirect {
  id       String @id @default(cuid())
  fromPath String @unique
  toPath   String

  @@map("redirects")
}

// ── Newsletter ──

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

// ── Contact ──

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
