# ── PostgreSQL ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=underarmour_store

# ── Backend ──
JWT_SECRET=changeme_random_64_char_string
BACKEND_PORT=9000

# ── URLs (important for Coolify) ──
# BACKEND_PUBLIC_URL = URL pública do backend que o browser do cliente acessa
# Em Coolify: domínio gerado para o service "backend" (ex: https://api.seudominio.com)
BACKEND_PUBLIC_URL=https://api.seudominio.com
# SITE_URL = URL pública do storefront
SITE_URL=https://seudominio.com

# ── Storefront ──
THEME_ADMIN_PASSWORD=changeme_admin_password
REVALIDATION_SECRET=changeme_revalidation_secret
STOREFRONT_PORT=3000

# ── SMTP (optional) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Stripe (optional) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
